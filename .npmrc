# Não baixar o Chromium bundled do puppeteer no `npm ci` (o download quebrava o build
# Nixpacks — sem unzip). Usamos o Chromium do sistema (apt → /usr/bin/chromium, ver
# nixpacks.toml). O npm exporta isto como npm_config_puppeteer_skip_download pro script
# de install do puppeteer, que é a forma CONFIÁVEL de pular (o .puppeteerrc.cjs e o env
# do nixpacks não foram lidos no passo de install). Bruno 2026-07-11.
puppeteer_skip_download=true
