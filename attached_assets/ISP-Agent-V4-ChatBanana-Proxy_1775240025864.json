    {
      "parameters": {
        "content": "# 🧠 SEÇÃO 3 — CONTEXTO + SCORE\n\nMonta o objeto de contexto completo:\nDados ERP + promessas de pagamento + score de risco.\nAlimenta o SDR e todos os agentes.",
        "height": 180,
        "width": 520,
        "color": 6
      },
      "id": "4ac312fa-abdb-43cf-8f3d-e5318730e5bb",
      "name": "🧠 CONTEXTO",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        -220,
        320
      ]
    },
    {
      "parameters": {
        "operation": "getAll",
        "tableId": "payment_promises",
        "returnAll": false,
        "limit": 5,
        "filterType": "string",
        "filterString": "=client_phone=eq.{{ $('Set Entrada').item.json.telefone.replace('@s.whatsapp.net','') }}&order=created_at.desc"
      },
      "id": "e7fc0adf-1b65-4cc6-a5e9-94f1c7a2db1c",
      "name": "Supabase: Promessas",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [
        240,
        360
      ],
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "const entrada = $('Set Entrada').item.json;\nconst erpRaw  = $('POST /api/n8n/erp — Enrichment Completo').item.json;\nconst erp     = erpRaw.result ?? erpRaw; // normaliza resposta {ok, result}\n\nconst pItems  = (() => { try { return $('Supabase: Promessas').all(); } catch(e){ return []; }})();\nconst allP    = pItems.map(i=>i.json).filter(p=>p&&p.id);\nconst ago30   = new Date(Date.now()-30*24*60*60*1000);\nconst recentP = allP.filter(p=>new Date(p.created_at)>ago30&&['pending','expired'].includes(p.status)).length;\nconst lastFul = allP[0]?allP[0].status==='paid':true;\n\nconst F = erp.financial ?? {};\nconst elig = recentP<2 && (F.days_late??0)<=60 && (F.amount_due??0)<=300 && lastFul!==false;\n\nlet risk=0;\nif((F.days_late??0)>60)risk+=50; else if((F.days_late??0)>30)risk+=30; else if((F.days_late??0)>15)risk+=15;\nif(recentP>=2)risk+=35; else if(recentP===1)risk+=15;\nif(!lastFul)risk+=25;\nif((erp.tickets?.recent??0)>3)risk+=10;\n\nconst ctx = {\n  ...erp,\n  mensagem:        entrada.mensagem_efetiva || entrada.mensagem,\n  contact_name:    entrada.contact_name,\n  conversation_id: entrada.conversation_id,\n  workspace_id:    entrada.workspace_id,\n  promises: {\n    this_month:     recentP,\n    last_fulfilled: lastFul,\n    eligible:       elig,\n  },\n  score: {\n    risk:             risk>60?'ALTO':risk>30?'MEDIO':'BAIXO',\n    risk_val:         risk,\n    loyalty:          (erp.cliente?.months??0)>24?'FIEL':(erp.cliente?.months??0)>6?'REGULAR':'NOVO',\n    promise_eligible: elig,\n  },\n};\nreturn [{json: ctx}];"
      },
      "id": "f77c330b-0d6b-4519-a140-d959b466269a",
      "name": "Code: Monta Contexto",
