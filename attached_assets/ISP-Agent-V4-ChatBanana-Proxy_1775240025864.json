    {
      "parameters": {
        "content": "# 🎯 SEÇÃO 4 — SDR + ROTEAMENTO\n\nClassificação por regras puras (sem API call).\nInstantâneo e determinístico.\nOverride: suspenso → sempre FINANCEIRO.",
        "height": 180,
        "width": 520,
        "color": 3
      },
      "id": "7c8ef459-52d1-4594-9bb3-c49d848035ba",
      "name": "🎯 SDR",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        -220,
        660
      ]
    },
    {
      "parameters": {
        "jsCode": "const ctx = $('Code: Monta Contexto').item.json;\nconst msg = (ctx.mensagem??'').toLowerCase();\nconst F=ctx.financial??{}, O=ctx.connection??{}, N=ctx.network??{};\n\n// Regras críticas (sem keywords)\nlet intent;\nif(F.is_suspended)                            intent='FINANCEIRO';\nelse if(O.is_offline&&N.clients_offline>5)    intent='INCIDENTE_REGIONAL';\nelse if(O.is_offline)                         intent='SUPORTE_OFFLINE';\nelse if(O.status==='online')                  intent='SUPORTE_ONLINE';\nelse                                          intent='GERAL';\n\n// Override por keywords\nconst kCan = ['cancelar','quero cancelar','desistir','quero sair','encerrar contrato'];\nconst kFin = ['segunda via','fatura','boleto','pagar','pix','pagamento','devo','cobrança','débito'];\nconst kSal = ['contratar','quanto custa','novo plano','assinar','instalar internet','planos disponíveis'];\n\nif(kCan.some(w=>msg.includes(w)))                         intent='CANCELAMENTO';\nelse if(kSal.some(w=>msg.includes(w))&&!F.is_suspended)   intent='VENDAS';\nelse if(kFin.some(w=>msg.includes(w))&&!F.is_suspended)   intent='FINANCEIRO';\n\nreturn [{json:{...ctx, intent}}];"
      },
