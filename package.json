  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch --import dotenv/config server/index.ts",
    "dev:no-watch": "cross-env NODE_ENV=development tsx --import dotenv/config server/index.ts",
    "dev:watch-scoped": "cross-env NODE_ENV=development tsx watch --ignore \"node_modules/**\" --ignore \"client/**\" --ignore \"dist/**\" --ignore \"attached_assets/**\" --ignore \".vite/**\" --ignore \"*.log\" --import dotenv/config server/index.ts",
    "dev:nodemon": "cross-env NODE_ENV=development nodemon --watch server --watch shared --ext ts,js,json --exec \"tsx --import dotenv/config server/index.ts\"",
    "dev:polling": "cross-env NODE_ENV=development CHOKIDAR_USEPOLLING=true CHOKIDAR_INTERVAL=1000 tsx watch --import dotenv/config server/index.ts",
    "build": "tsx script/build.ts",
    "start": "NODE_ENV=production node dist/index.cjs",
    "check": "tsc",
    "db:push": "drizzle-kit push"
  },
